# CoverageAgent — environment configuration
# Copy to .env and fill in your keys. .env is never committed.
#
# How it works: set COVERAGE_AGENT_MODEL to the model you want, then fill in
# that vendor's API key. All keys can coexist — the tool picks the right one
# automatically based on the chosen model. A missing key for the chosen model
# is a hard error (no silent fallback to a different vendor).

# --- Model selection ---------------------------------------------------------
# Change this to switch vendors. Run `coverage-agent models` to list all options.
COVERAGE_AGENT_MODEL=gemini/gemini-2.5-flash

# --- API keys (fill in the ones you have; leave the rest blank) --------------

# Google Gemini — gemini/* models. Free tier available.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI — openai/* models (gpt-4o, o4-mini, o3, …)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — anthropic/* models (claude-opus-4-8, claude-sonnet-4-6, …)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# xAI — xai/* models (grok-3, grok-3-mini, …)
# Get key: https://console.x.ai
XAI_API_KEY=

# Groq — groq/* models. Fast inference, free tier available.
# Get key: https://console.groq.com
GROQ_API_KEY=

# Cerebras — cerebras/* models. Extremely fast, free tier available.
# Get key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Mistral — mistral/* models (mistral-large, codestral, …)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# --- Retry and quality -------------------------------------------------------
# strict | balanced (default) | loose
# Controls max retry loops per gap (strict/balanced=3, loose=1).
EVAL_STRICTNESS=balanced
