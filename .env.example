# CoverageAgent — Required API keys
# Copy this file to .env and fill in real values before Day 4.
# .env is never committed. This file is committed with placeholder values only.

GEMINI_API_KEY=your_gemini_api_key_here
E2B_API_KEY=your_e2b_api_key_here
E2B_TEMPLATE_ID=
BRAINTRUST_API_KEY=your_braintrust_api_key_here

# Dry run mode — set to true to skip all real LLM and E2B calls (Days 1–3)
DRY_RUN=true
