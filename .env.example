# CoverageAgent — environment configuration
# Copy to .env and fill in real values. .env is never committed.

# --- LLM provider (default: Groq) ----------------------------------------
# Free tier: 30 RPM, 14400 TPM, 1000 RPD on llama-3.3-70b-versatile.
# Sign up at https://console.groq.com (no card required).
GROQ_API_KEY=

# Override the default model if you want something else.
# Examples: groq/llama-3.1-8b-instant, gemini/gemini-2.5-flash, openai/gpt-4o-mini
COVERAGE_AGENT_MODEL=groq/llama-3.3-70b-versatile

# --- Sandbox (E2B) -------------------------------------------------------
# Free tier: 100 sandbox hours/month. https://e2b.dev/dashboard
E2B_API_KEY=
E2B_TEMPLATE_ID=

# --- Optional: Braintrust evals + tracing --------------------------------
BRAINTRUST_API_KEY=

# --- Optional: alternative LLM providers (for BYOK overrides) ------------
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=

# --- Demo mode (shared server keys served from the UI) -------------------
# Used only when mode=demo. If unset, the demo path is disabled.
DEMO_GROQ_API_KEY=
DEMO_E2B_API_KEY=
DEMO_BRAINTRUST_API_KEY=

# --- Offline mode --------------------------------------------------------
# Set to true to skip all real LLM/E2B calls and use bundled fixtures.
# Useful for local development, CI, and screenshots.
OFFLINE_MODE=false
